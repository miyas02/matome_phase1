{
	"SITE_NAME": "5ch",
	"URL": "https://itest.5ch.net/pug/test/read.cgi/famicom/1763726316",
	"LOGIC": "Posts",
	"LIST_NODE": "//ul[@id='thread']",
	"POST_NODE": ".//li[contains(@class, 'threadview_response')]",
	"TEXT": {
		"NODE": ".//div[contains(@class, 'threadview_response_body')]",
		"TYPE": "text"
	},
	"USER_ID": {
		"NODE": ".//div[contains(@class, 'threadview_response_info')]",
		"TYPE": "text",
		"REGEX":"([0-9A-Za-z+\\-/]+)(?= \\[)"
	},
	"DATE": {
		"NODE": ".//div[contains(@class, 'threadview_response_info')]",
		"TYPE": "text",
		"REGEX":"\\d{4}/\\d{2}/\\d{2}\\(.\\)"
	},
	"REPLY": {
		"NODE": ".//a[contains(@class, 'threadview_response_body_link')]",
		"TYPE": "text"
	},
	"POST_ID": {
		"NODE": ".//div[contains(@class, 'threadview_response_info')]",
		"TYPE": "text",
		"REGEX": "\\s*(\\d{4})"
	}
}