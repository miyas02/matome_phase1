{
    "SITE_NAME": "5ch",
    "URL": "https://itest.5ch.net/pug/test/read.cgi/famicom/1763726316/l-",
    "EXTRACT": {
        "posts": {
            "CONTEXT": "//ul[@id='thread']",
            "ITEM": ".//li[contains(@class, 'threadview_response')]",
            "FIELDS": {
                "text": {
                    "NODE": ".//div[contains(@class, 'threadview_response_body')]",
                    "TYPE": "text"
                },
                "user_id": {
                    "NODE": ".//div[contains(@class, 'threadview_response_info')]",
                    "TYPE": "text",
                    "REGEX": "([0-9A-Za-z+\\-/]+)(?= \\[)"
                },
                "date": {
                    "NODE": ".//div[contains(@class, 'threadview_response_info')]",
                    "TYPE": "text",
                    "REGEX:": "\\d{4}/\\d{2}/\\d{2}\\(.\\)"
                },
                "reply": {
                    "NODE": ".//a[contains(@class, 'threadview_response_body_link')]",
                    "TYPE": "text"
                },
                "post_id": {
                    "NODE": ".//div[contains(@class, 'threadview_response_info')]",
                    "TYPE": "text",
                    "REGEX": "\\s*(\\d{4})"
                }
            }
        }
    }
}